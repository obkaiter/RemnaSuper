#!/usr/bin/env bash
set -o pipefail

resolve_app_dir() {
    local source="${BASH_SOURCE[0]}"
    local dir

    while [ -h "$source" ]; do
        dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
        source="$(readlink "$source")"
        [[ "$source" != /* ]] && source="$dir/$source"
    done

    cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

APP_DIR="$(resolve_app_dir)"

source "$APP_DIR/lib/config.sh"
source "$APP_DIR/lib/ui.sh"
source "$APP_DIR/lib/common.sh"
source "$APP_DIR/lib/update.sh"
source "$APP_DIR/lib/logs.sh"
source "$APP_DIR/lib/system.sh"
source "$APP_DIR/lib/geofiles.sh"
source "$APP_DIR/lib/menu.sh"

main() {
    check_root "$0"
    show_startup
    check_for_updates "$@"
    main_menu
}

main "$@"
