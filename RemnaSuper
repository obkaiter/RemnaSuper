    printf "  ${GREEN}10)${NC} 🚀 Выполнить Node Accelerator\n\n"
    printf "  ${RED}0)${NC} ❌ Выход\n\n"
    divider
    printf "Ваш выбор [0-10]: "
}

main_menu() {
    local choice
    while true; do
        show_menu
        read -r choice
        case $choice in
            1) fix_logs ;;
            2) check_status ;;
            3) setup_logrotate ;;
            4) collect_debug ;;
            5) cleanup_logs ;;
            6) restart_node ;;
            7) restart_agent ;;
            8) restore_backup ;;
            9) geofiles_menu ;;
            10) run_node_accelerator ;;
            0) exit_menu ;;
            *) warn "Неверный выбор"; sleep 1 ;;
        esac
    done
}

main() {
    check_root
    header "Запуск"
    info "Проверка окружения..."
    sleep 1
    main_menu
}

main "$@"
