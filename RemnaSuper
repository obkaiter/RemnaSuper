#===============================================================================
show_geofiles_menu() {
    clear
    printf "${BOLD}${CYAN}"
    printf "╔════════════════════════════════════════════╗\n"
    printf "║  RemnaSuper — geofiles                    ║\n"
    printf "╚════════════════════════════════════════════╝\n"
    printf "${NC}\n"
    printf "  ${GREEN}УСТАНОВКА${NC}\n"
    printf "  ${GREEN}1)${NC} Установить roscomvpn-geofiles\n"
    printf "  ${GREEN}2)${NC} Установить Loyalsoldier-geofiles\n"
    printf "  ${GREEN}3)${NC} Установить xray-routing geofiles\n"
    printf "  ${GREEN}4)${NC} Установить все geofiles\n\n"
    printf "  ${RED}УДАЛЕНИЕ${NC}\n"
    printf "  ${RED}5)${NC} Удалить roscomvpn-geofiles\n"
    printf "  ${RED}6)${NC} Удалить Loyalsoldier-geofiles\n"
    printf "  ${RED}7)${NC} Удалить xray-routing geofiles\n"
    printf "  ${RED}8)${NC} Удалить все geofiles\n\n"
    printf "  ${BLUE}0)${NC} Назад в главное меню\n\n"
    divider
    printf "Ваш выбор [0-8]: "
}

geofiles_menu() {
    local choice
    while true; do
        show_geofiles_menu
        read -r choice
        case $choice in
            1) install_roscomvpn_geofiles; pause ;;
            2) install_loyalsoldier_geofiles; pause ;;
            3) install_xray_routing_geofiles; pause ;;
            4) install_all_geofiles; pause ;;
            5) uninstall_roscomvpn_geofiles; pause ;;
            6) uninstall_loyalsoldier_geofiles; pause ;;
            7) uninstall_xray_routing_geofiles; pause ;;
            8) uninstall_all_geofiles; pause ;;
            0) return ;;
            *) warn "Неверный выбор"; sleep 1 ;;
        esac
    done
}

run_node_accelerator() {
    header "Выполнение Node Accelerator"

    check_command curl || { pause; return; }
    check_command sudo || { pause; return; }

    step "Запуск Node Accelerator..."
    curl -fsSL https://raw.githubusercontent.com/jestivald/node-accelerator/main/install.sh | sudo bash -s all

    local pipe_status=("${PIPESTATUS[@]}")
    local curl_exit="${pipe_status[0]}"
    local bash_exit="${pipe_status[1]}"
    if [ "$curl_exit" -eq 0 ] && [ "$bash_exit" -eq 0 ]; then
        success "Node Accelerator выполнен."
    else
        error "Node Accelerator завершился с ошибкой. curl: $curl_exit, bash: $bash_exit"
    fi

    pause
}

exit_menu() {
    header "❌ Завершение"
    success "Удачи!"
    exit 0
}

show_menu() {
    clear
    printf "${BOLD}${CYAN}"
    printf "╔════════════════════════════════════════════╗\n"
    printf "║  RemnaSuper — интерактивное меню          ║\n"
    printf "╚════════════════════════════════════════════╝\n"
    printf "${NC}\n"
    printf "Выберите действие:\n\n"
    printf "  ${GREEN}📜 ЛОГИ${NC}\n"
    printf "  ${GREEN}1)${NC} 🔧 Исправить логи в RemnaNode\n"
    printf "  ${GREEN}2)${NC} 📊 Информация о логах\n"
    printf "  ${GREEN}3)${NC} 🗂️  Настроить logrotate\n"
    printf "  ${GREEN}4)${NC} 🔍 Собрать логи\n"
    printf "  ${GREEN}5)${NC} 🧹 Очистить старые логи\n\n"
    printf "  ${GREEN}🔄 УПРАВЛЕНИЕ${NC}\n"
    printf "  ${GREEN}6)${NC} 🔄 Перезапустить ноду\n"
    printf "  ${GREEN}7)${NC} 🔄 Перезапустить агента\n"
    printf "  ${GREEN}8)${NC} ↩️  Восстановить из бэкапа\n\n"
